# Hashed JS/CSS bundles — safe to cache forever (Angular adds content hash to filename)
/main-*.js
  Cache-Control: public, max-age=31536000, immutable

/polyfills-*.js
  Cache-Control: public, max-age=31536000, immutable

/chunk-*.js
  Cache-Control: public, max-age=31536000, immutable

/styles-*.css
  Cache-Control: public, max-age=31536000, immutable

# Images — cache for 1 year (change filename to bust cache)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML and everything else — always revalidate
/*
  Cache-Control: public, max-age=0, must-revalidate
